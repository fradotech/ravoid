---
import "@/styles/global.css";
import { SiteConfig } from "@/app/config/site.config";
import SEOHead from "@/infrastructure/components/seo/SEOHead.astro";
import OrganizationSchema from "@/infrastructure/components/seo/OrganizationSchema.astro";
import type { SEOProps } from "@/infrastructure/components/seo/seo.type";
import Navbar from "./Navbar.astro";
import Footer from "./Footer.astro";

type Props = SEOProps;

const props = Astro.props;
---

<!doctype html>
<html lang={SiteConfig.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS Feed"
      href="/rss.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <SEOHead {...props} />
    <OrganizationSchema />
    <slot name="head" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PV5NVMJBH4"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }

      gtag("js", new Date());
      gtag("config", "G-PV5NVMJBH4");
    </script>

    <script is:inline>
      let sent = false;

      window.addEventListener("scroll", () => {
        if (sent) return;

        const scrollTop = window.scrollY;
        const docHeight = document.body.scrollHeight - window.innerHeight;
        const scrollPercent = scrollTop / docHeight;

        if (scrollPercent > 0.75) {
          sent = true;
          if (typeof gtag === "function") {
            gtag("event", "scroll_75", {
              event_category: "engagement",
              event_label: window.location.pathname,
            });
          }
        }
      });
    </script>

    <script type="text/javascript">
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = "https://www.clarity.ms/tag/" + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, "clarity", "script", "w3288qbzh2");
    </script>

    <script is:inline>
      (function () {
        const theme = localStorage.getItem("theme");
        if (theme === "light") {
          document.documentElement.classList.remove("dark");
        } else {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-sans">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
