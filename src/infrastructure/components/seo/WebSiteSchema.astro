---
import { SiteConfig } from '@/app/config/site.config';
import { Path } from '@/app/config/path.config';

const siteUrl = SiteConfig.siteUrl.replace(/\/$/, '');
const websiteId = `${siteUrl}/#website`;
const searchTarget = `${siteUrl}${Path.blog.index}?search={search_term_string}`;

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': websiteId,
      name: SiteConfig.name,
      url: siteUrl,
      potentialAction: {
        '@type': 'SearchAction',
        target: searchTarget,
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'WebPage',
      name: 'Infrastructure Economics for Serious SaaS Builders',
      description: 'Deep SaaS pricing analysis, tool comparisons, and infrastructure decisions.',
      url: `${siteUrl}/`,
      inLanguage: SiteConfig.language,
      isPartOf: { '@id': websiteId },
      about: {
        '@type': 'Thing',
        name: 'SaaS Pricing, Tools, Infrastructure',
      },
    },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
