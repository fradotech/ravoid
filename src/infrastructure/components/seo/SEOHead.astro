---
import { SiteConfig } from '@/app/config/site.config';
import { EnvConfig } from '@/app/config/env.config';
import type { SEOProps } from './seo.type';

type Props = SEOProps;

const {
  title,
  description = SiteConfig.description,
  ogImage,
  canonicalUrl,
  noIndex = false,
  type = 'website',
  publishedAt,
  updatedAt,
} = Astro.props;

const pageTitle = title ? `${title} | ${SiteConfig.name}` : SiteConfig.name;
const siteBase = Astro.site?.href || EnvConfig.siteUrl;
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteBase).href;
const ogImageUrl = ogImage || new URL('/og-default.webp', siteBase).href;
const metaDescription = description.length > 155
  ? description.slice(0, description.lastIndexOf(' ', 155)) + '...'
  : description;
---

<title>{pageTitle}</title>
<meta name="description" content={metaDescription} />
<link rel="canonical" href={canonical} />

{noIndex ? <meta name="robots" content="noindex, follow" /> : <meta name="robots" content="index, follow" />}

<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={SiteConfig.name} />
<meta property="og:locale" content={SiteConfig.language} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={metaDescription} />
<meta name="twitter:image" content={ogImageUrl} />

{publishedAt && <meta property="article:published_time" content={publishedAt} />}
{updatedAt && <meta property="article:modified_time" content={updatedAt} />}
