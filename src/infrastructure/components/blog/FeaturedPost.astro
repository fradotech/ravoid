---
import { Path } from '@/app/config/path.config';
import { formatDate } from '@/infrastructure/utils/date.util';
import type { Post } from '@/modules/post/post.type';

interface Props {
  post: Post;
}

const { post } = Astro.props;
---

<article class="group relative rounded-2xl overflow-hidden glass-card !p-0">
  <a href={Path.post.detail(post.slug)} class="block" aria-label={post.title}>
    <div class="aspect-[2/1] md:aspect-[21/9] overflow-hidden">
      <img
        src={post.heroImage}
        alt={post.title}
        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent" />
    <div class="absolute top-4 left-4 md:top-6 md:left-8">
      <span class="px-3 py-1 text-xs font-medium rounded-full bg-blue-600/80 text-white/90 backdrop-blur-sm">
        Featured
      </span>
    </div>
    <div class="absolute bottom-0 left-0 right-0 p-5 md:p-8 lg:p-10">
      <div class="mb-3 flex flex-wrap gap-1.5">
        {post.tags.slice(0, 3).map((tag) => (
          <span class="tag-outline px-2 py-0.5 text-[11px]">{tag.name}</span>
        ))}
      </div>
      <h2 class="text-xl md:text-2xl lg:text-3xl font-medium text-white line-clamp-2 leading-snug tracking-tight">
        {post.title}
      </h2>
      <p class="mt-2 md:mt-3 text-sm md:text-base text-gray-300/90 line-clamp-2 max-w-2xl leading-relaxed">
        {post.excerpt}
      </p>
      <time class="block mt-3 text-sm text-gray-400/80" datetime={post.publishedAt}>
        {formatDate(post.publishedAt)}
      </time>
    </div>
  </a>
</article>
