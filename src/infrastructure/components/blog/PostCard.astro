---
import { Path } from "@/app/config/path.config";
import { formatDate } from "@/infrastructure/utils/date.util";
import { truncate } from "@/infrastructure/utils/format.util";
import TagList from "./TagList.astro";
import type { Post } from "@/modules/post/post.type";

interface Props {
  post: Post;
}

const { post } = Astro.props;
---

<article class="group glass-card overflow-hidden">
  <a href={Path.post.detail(post.slug)} class="block" aria-label={post.title}>
    <div class="aspect-video overflow-hidden">
      <img
        src={post.thumbnail}
        alt={post.title}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>

    <div class="p-5">
      <h3
        class="font-medium text-gray-800 dark:text-gray-200 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2 leading-snug tracking-tight"
      >
        {post.title}
      </h3>

      <p
        class="mt-2 text-sm text-gray-500 dark:text-gray-400 line-clamp-3 leading-relaxed"
      >
        {truncate(post.excerpt, 140)}
      </p>

      <time
        class="block mt-3 text-xs text-gray-500 dark:text-gray-400"
        datetime={post.publishedAt}
      >
        {formatDate(post.publishedAt)}
      </time>
    </div>
  </a>
</article>
