---
import { Path } from '@/app/config/path.config';

interface Props {
  name: string;
  slug: string;
  size?: 'sm' | 'md';
}

const { name, slug, size = 'sm' } = Astro.props;

const sizeClasses = {
  sm: 'px-2 py-0.5 text-[11px]',
  md: 'px-2.5 py-0.5 text-xs',
};
---

<a
  href={Path.tags.detail(slug)}
  class:list={['tag-outline', sizeClasses[size]]}
>
  {name}
</a>
