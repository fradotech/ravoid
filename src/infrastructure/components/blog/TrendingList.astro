---
import { Path } from '@/app/config/path.config';
import { formatDate } from '@/infrastructure/utils/date.util';
import SectionHeader from '@/infrastructure/components/ui/SectionHeader.astro';
import type { Post } from '@/modules/post/post.type';

interface Props {
  posts: Post[];
  title?: string;
}

const { posts, title = 'Most Read This Week' } = Astro.props;
---

<div>
  <SectionHeader title={title} />
  <div class="space-y-4">
    {posts.map((post, index) => (
      <a href={Path.post.detail(post.slug)} class="flex gap-3 group">
        <span class="text-2xl font-medium text-gray-600 dark:text-gray-200/70 leading-none tabular-nums">
          {String(index + 1).padStart(2, '0')}
        </span>
        <div class="flex-1 min-w-0">
          <h4 class="text-sm font-medium text-gray-900 dark:text-gray-300 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2 leading-snug">
            {post.title}
          </h4>
          <time class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 block" datetime={post.publishedAt}>
            {formatDate(post.publishedAt)}
          </time>
        </div>
      </a>
    ))}
  </div>
</div>
