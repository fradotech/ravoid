---
import PostCard from './PostCard.astro';
import type { Post } from '@/modules/post/post.type';

interface Props {
  posts: Post[];
  columns?: 2 | 3;
}

const { posts, columns = 3 } = Astro.props;

const gridClasses = {
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
};
---

<div class:list={['grid gap-6', gridClasses[columns]]}>
  {posts.map((post) => (
    <PostCard post={post} />
  ))}
</div>
