---
import type { Post } from "@/modules/post/post.type";
import FeaturedPost from "@/infrastructure/components/blog/FeaturedPost.astro";

interface Props {
  post: Post;
}

const { post } = Astro.props;
---

<section class="max-w-6xl mx-auto px-4 pt-12 md:pt-16">
  <div class="flex items-center gap-2 mb-6">
    <span class="inline-block w-6 h-px bg-amber-500"></span>
    <span
      class="text-xs font-semibold tracking-wider uppercase text-amber-700 dark:text-amber-400"
    >
      Featured Analysis
    </span>
  </div>
  <FeaturedPost {post} />
</section>
