---
import type { Post, Tag } from "@/modules/post/post.type";
import PostGrid from "@/infrastructure/components/blog/PostGrid.astro";
import TrendingList from "@/infrastructure/components/blog/TrendingList.astro";
import TagCloud from "@/infrastructure/components/blog/TagCloud.astro";
import NewsletterForm from "@/infrastructure/components/newsletter/NewsletterForm.astro";
import SectionHeader from "@/infrastructure/components/ui/SectionHeader.astro";
import { Path } from "@/app/config/path.config";

interface Props {
  latest: Post[];
  trending: Post[];
  tags: Tag[];
}

const { latest, trending, tags } = Astro.props;
---

<section class="max-w-6xl mx-auto px-4 pt-16 md:pt-20">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <div class="lg:col-span-2">
      <SectionHeader title="Latest analysis" href={Path.blog.index} />
      <PostGrid posts={latest} columns={2} />
    </div>

    <aside class="space-y-8">
      <TrendingList posts={trending} />
      <NewsletterForm variant="compact" heading="Weekly in your inbox" />
      <div>
        <SectionHeader title="All topics" href={Path.tags.index} />
        <TagCloud {tags} />
      </div>
    </aside>
  </div>
</section>
