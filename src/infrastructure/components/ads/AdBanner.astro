---
interface Props {
  format?: 'horizontal' | 'rectangle' | 'sidebar';
  sticky?: boolean;
}

const { format = 'horizontal', sticky = false } = Astro.props;

const heightClasses: Record<string, string> = {
  horizontal: 'min-h-[90px]',
  rectangle: 'min-h-[250px]',
  sidebar: 'min-h-[600px]',
};
---

<div
  class:list={[
    'ad-container flex items-center justify-center rounded-xl border border-gray-200/40 dark:border-white/[0.06] bg-gray-50/50 dark:bg-white/[0.02]',
    heightClasses[format],
    sticky && 'sticky top-20',
  ]}
>
  <span class="text-xs text-gray-300 dark:text-gray-600">Advertisement</span>
</div>
