---
interface Props {
  format?: 'horizontal' | 'rectangle' | 'sidebar';
  sticky?: boolean;
}

const { format = 'horizontal', sticky = false } = Astro.props;

const heightClasses: Record<string, string> = {
  horizontal: 'min-h-[90px]',
  rectangle: 'min-h-[250px]',
  sidebar: 'min-h-[600px]',
};
---

<div
  class:list={[
    'ad-container flex items-center justify-center rounded-xl backdrop-blur-md bg-white/40 dark:bg-white/[0.05] shadow-sm',
    heightClasses[format],
    sticky && 'sticky top-20',
    'hidden' // TODO: enable
  ]}
>
  <span class="text-xs text-gray-500 dark:text-gray-400">Advertisement</span>
</div>
