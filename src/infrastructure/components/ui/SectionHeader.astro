---
interface Props {
  title: string;
  href?: string;
  linkText?: string;
}

const { title, href, linkText = 'View all' } = Astro.props;
---

<div class="flex items-center justify-between mb-5">
  <div class="flex items-center gap-3">
    <img src="/favicon-512.webp" alt="section icon" class="w-6 h-6 flex-shrink-0" />
    <h2 class="text-lg font-medium text-gray-800 dark:text-gray-200 tracking-tight">{title}</h2>
  </div>
  {href && (
    <a
      href={href}
      class="text-sm font-medium text-blue-500 dark:text-blue-400 hover:underline"
    >
      {linkText} &rarr;
    </a>
  )}
</div>
