---
interface Props {
  href: string;
  active?: boolean;
  label: string;
}

const { href, active = false, label } = Astro.props;
---

<a
  href={href}
  class:list={[
    'px-3.5 py-1.5 text-sm rounded-full font-medium transition-all duration-200 border',
    active
      ? 'bg-blue-600 text-white border-blue-600 shadow-md shadow-blue-500/20'
      : 'text-gray-500 border-gray-200 hover:border-gray-400 dark:text-gray-400 dark:border-white/[0.12] dark:hover:border-white/[0.25]',
  ]}
>
  {label}
</a>
