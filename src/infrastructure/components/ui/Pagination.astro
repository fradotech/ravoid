---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
  preserveParams?: Record<string, string | undefined>;
}

const { currentPage, totalPages, baseUrl, preserveParams = {} } = Astro.props;

function buildPageUrl(page: number): string {
  const url = new URL(baseUrl, 'http://localhost');

  Object.entries(preserveParams).forEach(([key, value]) => {
    if (value) url.searchParams.set(key, value);
  });

  if (page > 1) {
    url.searchParams.set('page', String(page));
  } else {
    url.searchParams.delete('page');
  }

  return `${url.pathname}${url.search}`;
}

const pages: (number | '...')[] = [];
for (let i = 1; i <= totalPages; i++) {
  if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
    pages.push(i);
  } else if (pages[pages.length - 1] !== '...') {
    pages.push('...');
  }
}
---

{totalPages > 1 && (
  <nav aria-label="Pagination" class="flex items-center justify-center gap-1 mt-8">
    {currentPage > 1 && (
      <a
        href={buildPageUrl(currentPage - 1)}
        class="px-3 py-2 text-sm rounded-lg text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
      >
        Prev
      </a>
    )}

    {pages.map((page) =>
      page === '...' ? (
        <span class="px-2 py-2 text-sm text-gray-400 dark:text-gray-600">...</span>
      ) : (
        <a
          href={buildPageUrl(page)}
          class:list={[
            'px-3 py-2 text-sm rounded-lg transition-colors',
            page === currentPage
              ? 'bg-blue-600 text-white'
              : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800',
          ]}
          aria-current={page === currentPage ? 'page' : undefined}
        >
          {page}
        </a>
      )
    )}

    {currentPage < totalPages && (
      <a
        href={buildPageUrl(currentPage + 1)}
        class="px-3 py-2 text-sm rounded-lg text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
      >
        Next
      </a>
    )}
  </nav>
)}
