---
import BaseLayout from '@/infrastructure/components/layout/BaseLayout.astro';
import PostGrid from '@/infrastructure/components/blog/PostGrid.astro';
import SectionHeader from '@/infrastructure/components/ui/SectionHeader.astro';
import SearchBar from '@/infrastructure/components/ui/SearchBar.astro';
import { Path } from '@/app/config/path.config';
import { getTrendingPosts } from '@/modules/post/post.api';

const trending = await getTrendingPosts(3);
---

<BaseLayout title="Page Not Found" description="The page you are looking for does not exist or has been moved." noIndex={true}>
  <div class="max-w-6xl mx-auto px-4 py-16 text-center">
    <p class="text-6xl font-bold text-blue-600 dark:text-blue-400 mb-4">404</p>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-2">Page not found</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8">
      The page you are looking for does not exist or has been moved.
    </p>

    <div class="max-w-md mx-auto mb-12">
      <SearchBar placeholder="Search for articles..." />
    </div>

    <div class="flex justify-center gap-4 mb-16">
      <a
        href={Path.index}
        class="px-6 py-2.5 text-sm font-medium rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors"
      >
        Go Home
      </a>
      <a
        href={Path.blog.index}
        class="px-6 py-2.5 text-sm font-medium rounded-lg glass-input text-gray-700 dark:text-gray-300 hover:bg-gray-100/50 dark:hover:bg-white/10 transition-all"
      >
        Browse Articles
      </a>
    </div>

    {trending.length > 0 && (
      <div class="text-left max-w-4xl mx-auto">
        <SectionHeader title="Popular Articles" href={Path.blog.index} />
        <PostGrid posts={trending} columns={3} />
      </div>
    )}
  </div>
</BaseLayout>
