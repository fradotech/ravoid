---
export const prerender = true;

import BaseLayout from "@/infrastructure/components/layout/BaseLayout.astro";
import WebSiteSchema from "@/infrastructure/components/seo/WebSiteSchema.astro";
import AdBanner from "@/infrastructure/components/ads/AdBanner.astro";
import AuthorCard from "@/infrastructure/author/AuthorCard.astro";
import HomeHero from "@/infrastructure/components/home/HomeHero.astro";
import HomeFeaturedSection from "@/infrastructure/components/home/HomeFeaturedSection.astro";
import HomeValueProps from "@/infrastructure/components/home/HomeValueProps.astro";
import HomeLatestSection from "@/infrastructure/components/home/HomeLatestSection.astro";
import HomeNewsletterSection from "@/infrastructure/components/home/HomeNewsletterSection.astro";
import { SiteConfig } from "@/app/config/site.config";
import { getHomeData } from "@/modules/home/home.api";
import { getAllTags } from "@/modules/tag/tag.api";
import type { Tag } from "@/modules/post/post.type";

const { featured, trending, latest } = await getHomeData();
const tags = await getAllTags();

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Latest Articles — ${SiteConfig.name}`,
  itemListElement: latest.slice(0, 10).map((post, idx) => ({
    "@type": "ListItem",
    position: idx + 1,
    url: new URL(
      `/blog/${post.slug}`,
      Astro.site,
    ).href,
    name: post.title,
  })),
};

const featuredTopics: Tag[] = [
  { name: "AI Cost", slug: "cost-analysis" },
  { name: "AI Agents", slug: "agents" },
  { name: "LLM", slug: "llm" },
  { name: "Anthropic", slug: "anthropic" },
  { name: "Infrastructure", slug: "infrastructure" },
  { name: "SaaS Pricing", slug: "pricing" },
  { name: "Serverless", slug: "serverless" },
];
---

<BaseLayout
  title={`${SiteConfig.tagline} | ${SiteConfig.name}`}
  description="Deep technical analysis of AI infrastructure cost, SaaS pricing models, and engineering decisions. Stage-specific guidance for engineering leaders building production systems, with real numbers and opinionated recommendations."
>
  <WebSiteSchema slot="head" />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(itemListSchema)}
  />

  <HomeHero tagline={SiteConfig.tagline} description="Deep breakdowns of AI infrastructure cost, SaaS pricing, and engineering decisions. Real numbers, stage-specific guidance, and opinions shaped by production experience." featuredTopics={featuredTopics} />

  <HomeFeaturedSection post={featured} />

  <HomeValueProps />

  <HomeLatestSection {latest} {trending} {tags} />

  <!-- SINGLE AD SLOT -->
  <section class="max-w-6xl mx-auto px-4 pt-16">
    <AdBanner format="horizontal" />
  </section>

  <HomeNewsletterSection />

  <!-- AUTHOR CARD -->
  <section class="max-w-6xl mx-auto px-4 pt-16 md:pt-20">
    <AuthorCard />
  </section>
</BaseLayout>
