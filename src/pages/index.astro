---
export const prerender = false;

import BaseLayout from "@/infrastructure/components/layout/BaseLayout.astro";
import WebSiteSchema from "@/infrastructure/components/seo/WebSiteSchema.astro";
import FeaturedPost from "@/infrastructure/components/blog/FeaturedPost.astro";
import PostGrid from "@/infrastructure/components/blog/PostGrid.astro";
import TrendingList from "@/infrastructure/components/blog/TrendingList.astro";
import TagCloud from "@/infrastructure/components/blog/TagCloud.astro";
import AdBanner from "@/infrastructure/components/ads/AdBanner.astro";
import SectionHeader from "@/infrastructure/components/ui/SectionHeader.astro";
import { SiteConfig } from "@/app/config/site.config";
import { Path } from "@/app/config/path.config";
import { getHomeData } from "@/modules/home/home.api";
import { getAllTags } from "@/modules/tag/tag.api";

const { featured, trending, latest } = await getHomeData();
const tags = await getAllTags();
---

<BaseLayout
  title={SiteConfig.tagline}
  description="Deep SaaS pricing analysis, tool comparisons, and infrastructure decisions. Learn how to choose the right stack, pricing model, and growth strategy. Latest articles, trending topics, and expert analysis."
>
  <WebSiteSchema slot="head" />
  <div class="max-w-7xl mx-auto px-4 py-8">
    <section class="mb-10 text-center">
      <h1
        class="text-2xl md:text-3xl font-medium tracking-tight text-gray-900 dark:text-gray-100 max-w-4xl mx-auto"
      >
        {SiteConfig.tagline}
      </h1>
      <p
        class="mt-2 text-sm md:text-base text-gray-500 dark:text-gray-400 max-w-4xl mx-auto"
      >
        {SiteConfig.description}
      </p>
    </section>

    <section>
      <FeaturedPost post={featured} />
    </section>

    <section class="mt-12">
      <AdBanner format="horizontal" />
    </section>

    <section class="mt-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          <SectionHeader title="Latest" href={Path.blog.index} />
          <PostGrid posts={latest} columns={2} />
        </div>

        <aside class="space-y-8">
          <TrendingList posts={trending} />
          <div>
            <SectionHeader title="Topics" href={Path.tags.index} />
            <TagCloud tags={tags} />
          </div>
        </aside>
      </div>
    </section>

    <section class="mt-12">
      <AdBanner format="horizontal" />
    </section>
  </div>
</BaseLayout>
