---
export const prerender = false;

import BaseLayout from "@/infrastructure/components/layout/BaseLayout.astro";
import WebSiteSchema from "@/infrastructure/components/seo/WebSiteSchema.astro";
import FeaturedPost from "@/infrastructure/components/blog/FeaturedPost.astro";
import PostGrid from "@/infrastructure/components/blog/PostGrid.astro";
import TrendingList from "@/infrastructure/components/blog/TrendingList.astro";
import TagCloud from "@/infrastructure/components/blog/TagCloud.astro";
import AdBanner from "@/infrastructure/components/ads/AdBanner.astro";
import SectionHeader from "@/infrastructure/components/ui/SectionHeader.astro";
import { SiteConfig } from "@/app/config/site.config";
import { Path } from "@/app/config/path.config";
import { getHomeData } from "@/modules/home/home.api";
import { getAllTags } from "@/modules/tag/tag.api";

const { featured, trending, latest } = await getHomeData();
const tags = await getAllTags();
---

<BaseLayout
  title="SaaS Pricing & Infrastructure Insights for Builders"
  description="Deep SaaS pricing analysis, tool comparisons, and infrastructure decisions. Learn how to choose the right stack, pricing model, and growth strategy. Latest articles, trending topics, and expert analysis."
>
  <WebSiteSchema slot="head" />
  <div class="max-w-7xl mx-auto px-4 py-8">
    <section class="mb-10 text-center">
      <h1
        class="text-2xl md:text-3xl font-medium tracking-tight text-gray-900 dark:text-gray-100"
      >
        {SiteConfig.tagline}
      </h1>
      <p
        class="mt-2 text-sm md:text-base text-gray-500 dark:text-gray-400 max-w-xl mx-auto"
      >
        {SiteConfig.description}
      </p>
    </section>

    <section>
      <FeaturedPost post={featured} />
    </section>

    <section class="mt-12">
      <SectionHeader title="Core Topics" />
      <p class="text-sm text-gray-500 dark:text-gray-400 -mt-3 mb-5">
        Explore key SaaS topics we cover
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {
          [
            {
              title: "SaaS Pricing",
              href: Path.post.detail(
                "saas-pricing-models-subscription-vs-usage-based",
              ),
              description:
                "Subscription vs usage-based pricing, hybrid models, and monetization strategy",
            },
            {
              title: "Tool Comparisons",
              href: Path.post.detail("how-to-compare-saas-tools-objectively"),
              description:
                "How to evaluate SaaS tools, avoid bias, and choose the right stack",
            },
            {
              title: "Infrastructure",
              href: Path.post.detail("vercel-vs-netlify-vs-cloudflare-pages"),
              description:
                "Hosting, performance, and cost trade-offs for modern SaaS apps",
            },
          ].map((topic) => (
            <a href={topic.href} class="group glass-card p-5">
              <h3 class="font-medium text-gray-800 dark:text-gray-200 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors tracking-tight">
                {topic.title}
              </h3>
              <p class="mt-2 text-sm text-gray-500 dark:text-gray-400/80 leading-relaxed">
                {topic.description}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mt-12 max-w-3xl">
      <p class="text-sm leading-relaxed text-gray-500 dark:text-gray-400">
        Choosing the right pricing model, tech stack, and hosting platform can
        define the trajectory of a SaaS product. We break down real trade-offs
        between
        <a
          href="/blog/saas-pricing-models-subscription-vs-usage-based"
          class="text-blue-500 hover:underline"
          >subscription and usage-based pricing</a
        >, compare tools side by side in our
        <a
          href="/blog/how-to-compare-saas-tools-objectively"
          class="text-blue-500 hover:underline">SaaS evaluation framework</a
        >, and analyze infrastructure decisions in our
        <a
          href="/blog/vercel-vs-netlify-vs-cloudflare-pages"
          class="text-blue-500 hover:underline">hosting comparison guide</a
        >.
      </p>
    </section>

    <section class="mt-12">
      <AdBanner format="horizontal" />
    </section>

    <section class="mt-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          <SectionHeader title="Latest" href={Path.blog.index} />
          <PostGrid posts={latest} columns={2} />
        </div>

        <aside class="space-y-8">
          <TrendingList posts={trending} />
          <div>
            <SectionHeader title="Topics" href={Path.tags.index} />
            <TagCloud tags={tags} />
          </div>
        </aside>
      </div>
    </section>

    <section class="mt-12">
      <AdBanner format="horizontal" />
    </section>
  </div>
</BaseLayout>
