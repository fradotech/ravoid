---
import StaticPageLayout from '@/infrastructure/components/layout/StaticPageLayout.astro';
import { SiteConfig } from '@/app/config/site.config';
import { Path } from '@/app/config/path.config';
---

<StaticPageLayout title="About" description={`About ${SiteConfig.name}`}>
  <p>
    Welcome to {SiteConfig.name}, Deep SaaS pricing analysis, tool comparisons, and infrastructure decisions. Learn how to choose the right stack, pricing model, and growth strategy.
    We provide in-depth analysis, guides, and news to help you make informed financial decisions.
  </p>

  <h2>Our Mission</h2>
  <p>
    We believe that SaaS and startup education should be accessible to everyone.
    Our team of experienced analysts and writers work to break down complex
    SaaS and startup topics into clear, actionable content.
  </p>

  <h2>What We Cover</h2>
  <ul>
    <li>SaaS pricing models and strategies</li>
    <li>Startup funding and fundraising</li>
    <li>Market analysis and trend reports</li>
    <li>SaaS and startup news and updates</li>
  </ul>

  <h2>Contact</h2>
  <p>
    Have questions or feedback? We would love to hear from you.
    Reach out to us through our <a href={Path.contact}>contact page</a>.
  </p>
</StaticPageLayout>
