---
export const prerender = false;

import BaseLayout from '@/infrastructure/components/layout/BaseLayout.astro';
import Breadcrumb from '@/infrastructure/components/seo/Breadcrumb.astro';
import TagList from '@/infrastructure/components/blog/TagList.astro';
import TrendingList from '@/infrastructure/components/blog/TrendingList.astro';
import RecentPosts from '@/infrastructure/components/blog/RecentPosts.astro';
import ShareButtons from '@/infrastructure/components/ui/ShareButtons.astro';
import AdBanner from '@/infrastructure/components/ads/AdBanner.astro';
import TableOfContents from '@/modules/post/components/TableOfContents.astro';
import PostContent from '@/modules/post/components/PostContent.astro';
import SuggestionReading from '@/modules/post/components/SuggestionReading.astro';
import { Path } from '@/app/config/path.config';
import { formatDate } from '@/infrastructure/utils/date.util';
import { extractToc, renderMarkdown } from '@/infrastructure/utils/markdown.util';
import { getFeaturedPost, getPostBySlug, getRelatedPosts, getTrendingPosts, getRecentPosts } from '@/modules/post/post.api';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const post = await getPostBySlug(slug);

if (!post) {
  return Astro.redirect('/404');
}

const toc = extractToc(post.content);
const tagSlugs = post.tags.map((t) => t.slug);

const featured = await getFeaturedPost();

const [html, related, trending, recent] = await Promise.all([
  renderMarkdown(post.content),
  getRelatedPosts(post.slug, tagSlugs),
  getTrendingPosts(5, [featured.slug, post.slug]),
  getRecentPosts(4),
]);

const pageUrl = new URL(Path.post.detail(post.slug), Astro.site).href;
const canonicalUrl = post.seo.canonicalUrl ?? pageUrl;
const description = post.seo.metaDescription || post.excerpt;

const publishedTime = new Date(post.publishedAt).getTime();
const modifiedTime = new Date(post.updatedAt).getTime();
const dateModified =
  Number.isFinite(modifiedTime) && modifiedTime >= publishedTime ? post.updatedAt : post.publishedAt;

const articleSection = post.tags[0]?.name ?? 'Blog';
const keywords = post.tags.map((t) => t.name).join(', ');

const blogPostingJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description,
  image: {
    '@type': 'ImageObject',
    url: post.heroImage,
    width: 1200,
    height: 630,
  },
  author: {
    '@type': 'Person',
    name: 'Framesta Fernando',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Ravoid',
    logo: {
      '@type': 'ImageObject',
      url: 'https://ravoid.com/favicon.svg',
    },
  },
  datePublished: post.publishedAt,
  dateModified,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  articleSection,
  ...(keywords ? { keywords } : {}),
};

---

<BaseLayout
  title={post.seo.metaTitle}
  description={post.seo.metaDescription}
  ogImage={post.seo.ogImage}
  canonicalUrl={post.seo.canonicalUrl}
  noIndex={post.seo.noIndex}
  type="article"
  publishedAt={post.publishedAt}
  updatedAt={post.updatedAt}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(blogPostingJsonLd)} />

  <article class="max-w-6xl mx-auto px-4 py-8">
    <Breadcrumb items={[
      { label: 'Blog', href: Path.blog.index },
      { label: post.title },
    ]} />

    <header class="mb-8">
      <div class="mb-3">
        <TagList tags={post.tags} size="md" />
      </div>
      <h1 class="text-2xl md:text-[1.875rem] font-medium text-gray-800 dark:text-gray-200 leading-snug tracking-tight">
        {post.title}
      </h1>
      <div class="mt-3 flex items-center flex-wrap gap-x-1.5 text-sm text-gray-500 dark:text-gray-400">
        <span>By</span>
        <span itemprop="author" class="text-gray-600 dark:text-gray-300">Framesta Fernando</span>
        <span>&middot;</span>
        <time datetime={dateModified}>{formatDate(dateModified)}</time>
      </div>
    </header>

    <div class="aspect-[21/9] rounded-2xl overflow-hidden mb-8 bg-gray-100 dark:bg-gray-800">
      <img
        src={post.heroImage}
        alt={post.title}
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <PostContent html={html} />

        <div class="mt-10 pt-6 border-t border-gray-200/60 dark:border-white/[0.08]">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <TagList tags={post.tags} limit={10} size="md" />
            <ShareButtons url={pageUrl} title={post.title} />
          </div>
        </div>

        <div class="mt-8">
          <AdBanner format="horizontal" />
        </div>

        <SuggestionReading posts={related} />
      </div>

      <aside class="hidden lg:block">
        <div class="sticky top-20 space-y-6">
          <TableOfContents items={toc} />
          <AdBanner format="rectangle" />
          <TrendingList posts={trending} />
          <RecentPosts posts={recent} />
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>
