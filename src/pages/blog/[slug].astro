---
export const prerender = true;

import BaseLayout from "@/infrastructure/components/layout/BaseLayout.astro";
import Breadcrumb from "@/infrastructure/components/seo/Breadcrumb.astro";
import TagList from "@/infrastructure/components/blog/TagList.astro";
import TrendingList from "@/infrastructure/components/blog/TrendingList.astro";
import RecentPosts from "@/infrastructure/components/blog/RecentPosts.astro";
import ShareButtons from "@/infrastructure/components/ui/ShareButtons.astro";
import AdBanner from "@/infrastructure/components/ads/AdBanner.astro";
import NewsletterForm from "@/infrastructure/components/newsletter/NewsletterForm.astro";
import TableOfContents from "@/modules/post/components/TableOfContents.astro";
import PostContent from "@/modules/post/components/PostContent.astro";
import SuggestionReading from "@/modules/post/components/SuggestionReading.astro";
import { Path } from "@/app/config/path.config";
import { formatDate } from "@/infrastructure/utils/date.util";
import {
  extractToc,
  extractFAQs,
  renderMarkdown,
} from "@/infrastructure/utils/markdown.util";
import {
  getAllPosts,
  getFeaturedPost,
  getRelatedPosts,
  getTrendingPosts,
  getRecentPosts,
} from "@/modules/post/post.api";
import type { Post } from "@/modules/post/post.type";
import AuthorCard from "@/infrastructure/author/AuthorCard.astro";
import { SiteConfig } from "@/app/config/site.config";

export async function getStaticPaths() {
  const { data } = await getAllPosts({ pageSize: 10000 });
  return data.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: Post };

const toc = extractToc(post.content);
const faqs = extractFAQs(post.content);
const tagSlugs = post.tags.map((t) => t.slug);

const featured = await getFeaturedPost();

const [html, related, trending, recent] = await Promise.all([
  renderMarkdown(post.content),
  getRelatedPosts(post.slug, tagSlugs),
  getTrendingPosts(5, [featured.slug, post.slug]),
  getRecentPosts(4),
]);

const pageUrl = new URL(Path.post.detail(post.slug), Astro.site).href;
const canonicalUrl = post.seo.canonicalUrl ?? pageUrl;
const description = post.seo.metaDescription || post.excerpt;

const publishedTime = new Date(post.publishedAt).getTime();
const modifiedTime = new Date(post.updatedAt).getTime();
const dateModified =
  Number.isFinite(modifiedTime) && modifiedTime >= publishedTime
    ? post.updatedAt
    : post.publishedAt;

const articleSection = post.tags[0]?.name ?? "Blog";
const keywords = post.tags.map((t) => t.name).join(", ");
const tagNames = post.tags.map((t) => t.name);
const wordCount = post.content.trim().split(/\s+/).filter(Boolean).length;

const blogPostingJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  description,
  inLanguage: SiteConfig.language,
  isAccessibleForFree: true,
  wordCount,
  image: {
    "@type": "ImageObject",
    url: post.heroImage,
    width: SiteConfig.ogImage.width,
    height: SiteConfig.ogImage.height,
  },
  author: {
    "@type": "Person",
    "@id": `${SiteConfig.author.url}#person`,
    name: SiteConfig.author.name,
    url: SiteConfig.author.url,
  },
  publisher: {
    "@type": "Organization",
    name: "Ravoid",
    logo: {
      "@type": "ImageObject",
      url: "https://ravoid.com/favicon.ico",
    },
  },
  datePublished: post.publishedAt,
  dateModified,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
  articleSection,
  ...(keywords ? { keywords } : {}),
};

const faqPageJsonLd =
  faqs.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqs.map((f) => ({
          "@type": "Question",
          name: f.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: f.answer,
          },
        })),
      }
    : null;
---

<BaseLayout
  title={post.seo.metaTitle}
  description={post.seo.metaDescription}
  ogImage={post.seo.ogImage}
  ogImageAlt={post.title}
  canonicalUrl={post.seo.canonicalUrl}
  noIndex={post.seo.noIndex}
  type="article"
  publishedAt={post.publishedAt}
  updatedAt={post.updatedAt}
  section={articleSection}
  tags={tagNames}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(blogPostingJsonLd)}
  />

  {
    faqPageJsonLd && (
      <script
        slot="head"
        type="application/ld+json"
        set:html={JSON.stringify(faqPageJsonLd)}
      />
    )
  }

  <article class="max-w-6xl mx-auto px-4 py-8">
    <Breadcrumb
      items={[{ label: "Blog", href: Path.blog.index }, { label: post.title }]}
    />

    <header class="mb-8">
      <div class="mb-3">
        <TagList tags={post.tags} size="md" />
      </div>
      <h1
        class="text-2xl md:text-[1.875rem] font-medium text-gray-800 dark:text-gray-200 leading-snug tracking-tight"
      >
        {post.title}
      </h1>
      <div class="mt-4 flex items-center gap-4">
        <!-- Foto Profil -->
        <img
          src="https://media.licdn.com/dms/image/v2/D4D03AQE_vcPpSpWXfA/profile-displayphoto-shrink_200_200/B4DZXKAxxqHYAY-/0/1742850957386?e=2147483647&v=beta&t=JpASrSsdp9PSQRwlnQQ8C3PYdU_q0aMiTE7NkVjbv8Y"
          alt="Framesta Fernando"
          class="w-10 h-10 rounded-full object-cover flex-shrink-0"
          width="40"
          height="40"
        />

        <!-- Byline Text -->
        <div>
          <div
            class="flex items-center flex-wrap gap-x-1.5 text-sm text-gray-500 dark:text-gray-400"
          >
            <span>By</span>
            <span
              itemprop="author"
              class="text-gray-600 dark:text-gray-300 font-medium"
              >Framesta Fernando</span
            >
            <span>&middot;</span>
            <time datetime={dateModified}>{formatDate(dateModified)}</time>
          </div>
        </div>
      </div>
    </header>

    <div
      class="aspect-[21/9] rounded-2xl overflow-hidden mb-8 bg-gray-100 dark:bg-gray-800"
    >
      <img
        src={post.heroImage}
        alt={post.title}
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <PostContent html={html} />

        <div class="mt-10">
          <NewsletterForm variant="inline" />
        </div>

        <div
          class="mt-10 pt-6 border-t-0 border-b-0 border-r-0 border-l-4 border-l-blue-500/40 pl-6"
        >
          <div class="flex flex-wrap items-center justify-between gap-4">
            <TagList tags={post.tags} limit={10} size="md" />
            <ShareButtons url={pageUrl} title={post.title} />
          </div>
        </div>

        <div class="mt-8">
          <AdBanner format="horizontal" />
        </div>

        <AuthorCard />

        <SuggestionReading posts={related} />
      </div>

      <aside class="hidden lg:block">
        <div class="sticky top-20 space-y-6">
          <TableOfContents items={toc} />
          <NewsletterForm variant="compact" heading="Stay in the loop" />
          <AdBanner format="rectangle" />
          <TrendingList posts={trending} />
          <RecentPosts posts={recent} />
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>
