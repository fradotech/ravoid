---
export const prerender = false;

import BaseLayout from '@/infrastructure/components/layout/BaseLayout.astro';
import Breadcrumb from '@/infrastructure/components/seo/Breadcrumb.astro';
import PostGrid from '@/infrastructure/components/blog/PostGrid.astro';
import Pagination from '@/infrastructure/components/ui/Pagination.astro';
import { Path } from '@/app/config/path.config';
import { pluralize } from '@/infrastructure/utils/format.util';
import { getTagBySlug } from '@/modules/tag/tag.api';
import { getAllPosts } from '@/modules/post/post.api';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const tag = await getTagBySlug(slug);

if (!tag) {
  return Astro.redirect('/404');
}

const page = Number(Astro.url.searchParams.get('page')) || 1;

// Content is static; let Vercel's CDN cache rendered tag pages and revalidate in the background.
Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=0, s-maxage=3600, stale-while-revalidate=86400',
);

const postsResult = await getAllPosts({ page, filters: { tag: slug } });

// Self-referencing canonical so paginated tag pages stay indexable.
const canonicalUrl = new URL(
  page > 1 ? `${Path.tags.detail(slug)}?page=${page}` : Path.tags.detail(slug),
  Astro.site,
).href;
---

<BaseLayout title={tag.name} description={`Articles tagged with ${tag.name}`} canonicalUrl={canonicalUrl}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <Breadcrumb items={[
      { label: 'Tags', href: Path.tags.index },
      { label: tag.name },
    ]} />

    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-2">{tag.name}</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8">{pluralize(tag.postCount, 'article')}</p>

    {postsResult.data.length > 0 ? (
      <>
        <PostGrid posts={postsResult.data} />

        {postsResult.meta && (
          <Pagination
            currentPage={page}
            totalPages={postsResult.meta.totalPage}
            baseUrl={Path.tags.detail(slug)}
          />
        )}
      </>
    ) : (
      <p class="text-center py-16 text-lg text-gray-500 dark:text-gray-400">
        No articles found for this tag.
      </p>
    )}
  </div>
</BaseLayout>
