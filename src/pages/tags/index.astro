---
export const prerender = true;

import BaseLayout from '@/infrastructure/components/layout/BaseLayout.astro';
import { Path } from '@/app/config/path.config';
import { pluralize } from '@/infrastructure/utils/format.util';
import { getAllTags } from '@/modules/tag/tag.api';

const tags = await getAllTags();
---

<BaseLayout title="Tags" description="Browse articles by topic">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-8">Tags</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      {tags.map((tag) => (
        <a
          href={Path.tags.detail(tag.slug)}
          class="flex items-center justify-between p-4 glass-card"
        >
          <span class="font-medium text-gray-900 dark:text-gray-100">{tag.name}</span>
          <span class="text-sm text-gray-500 dark:text-gray-400">{pluralize(tag.postCount || 0, 'post')}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
