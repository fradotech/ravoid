---
import StaticPageLayout from "@/infrastructure/components/layout/StaticPageLayout.astro";
import { SiteConfig } from "@/app/config/site.config";
---

<StaticPageLayout
  title="Contact"
  description="Reach out to discuss SaaS infrastructure, AI in production, or business inquiries."
>
  <div class="max-w-3xl mx-auto space-y-8 text-gray-800 dark:text-gray-200">
    <!-- Header Section -->
    <div>
      <h1
        class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl"
      >
        Let's Talk
      </h1>
      <p class="mt-4 text-lg leading-relaxed">
        I don't do generic tech fluff, and I prefer to keep conversations the
        same way. Whether you want to challenge a premise in an article, share a
        production war story, or discuss a business partnership, here’s how to
        reach out.
      </p>
    </div>

    <!-- Contact Cards Grid -->
    <div class="grid gap-6 sm:grid-cols-2 mt-8">
      <!-- Card 1: Discussions (LinkedIn) -->
      <div
        class="p-6 rounded-2xl bg-gray-50 border border-gray-200 dark:bg-gray-800/50 dark:border-gray-700 flex flex-col h-full"
      >
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
          Discussions & Feedback
        </h2>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 flex-grow">
          For quick questions, feedback, or discussing infrastructure and AI
          scaling realities, LinkedIn is the fastest way to get my attention.
        </p>
        <div class="mt-6">
          <a
            href="https://linkedin.com/in/fradotech"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium transition-colors"
          >
            Connect on LinkedIn
            <svg
              class="w-4 h-4 ml-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
            >
          </a>
        </div>
      </div>

      <!-- Card 2: Business & Deep Dives (Email) -->
      <div
        class="p-6 rounded-2xl bg-gray-50 border border-gray-200 dark:bg-gray-800/50 dark:border-gray-700 flex flex-col h-full"
      >
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
          Business Inquiries
        </h2>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 flex-grow">
          For sponsorships, partnerships, or consulting regarding your SaaS
          architecture, drop me a direct email.
        </p>
        <div class="mt-6">
          <a
            href="mailto:fradotech.id@gmail.com"
            class="inline-flex items-center text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium transition-colors"
          >
            fradotech.id@gmail.com
            <svg
              class="w-4 h-4 ml-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path></svg
            >
          </a>
        </div>
      </div>
    </div>

    <!-- Expectations Section -->
    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
      <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">
        What to expect
      </h2>
      <p class="mt-4 leading-relaxed">
        I read every message, but I might not reply immediately if I'm deep in a
        sprint or wrestling with a production issue. If it's a cold pitch for a
        dev tool that doesn't solve a real scaling problem, I'll likely skip it.
        But if it's a genuine conversation about engineering realities, I'll get
        back to you as soon as I can.
      </p>
    </div>
  </div>
</StaticPageLayout>
