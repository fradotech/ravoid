---
interface Props {
  html: string;
}

const { html } = Astro.props;
---

<div class="post-content prose dark:prose-invert max-w-none prose-headings:scroll-mt-20 prose-headings:font-semibold prose-h1:text-2xl prose-h2:text-xl prose-h3:text-lg prose-h4:text-base prose-p:text-[0.95rem] prose-p:leading-relaxed prose-li:text-[0.95rem] prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-a:font-normal prose-img:rounded-lg prose-strong:font-semibold prose-blockquote:font-normal prose-blockquote:not-italic" set:html={html} />
