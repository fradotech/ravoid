---
interface Props {
  html: string;
}

const { html } = Astro.props;
---

<div class="post-content prose dark:prose-invert max-w-none prose-headings:scroll-mt-20 prose-headings:font-medium prose-headings:tracking-tight prose-h2:text-[1.2rem] md:prose-h2:text-[1.35rem] prose-h2:mt-10 prose-h2:mb-4 prose-h3:text-[1.05rem] md:prose-h3:text-[1.125rem] prose-h3:mt-8 prose-h3:mb-3 prose-h4:text-[0.95rem] md:prose-h4:text-base prose-p:text-[0.95rem] md:prose-p:text-base prose-p:leading-[1.75] prose-li:text-[0.95rem] md:prose-li:text-base prose-li:leading-[1.75] prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-a:font-normal prose-a:underline-offset-2 prose-img:rounded-xl prose-strong:font-medium prose-blockquote:text-[0.9rem] md:prose-blockquote:text-[0.95rem] prose-blockquote:font-normal prose-blockquote:not-italic prose-hr:border-l-4 prose-hr:border-l-blue-500/30 prose-hr:border-r-0 prose-hr:border-t-0 prose-hr:border-b-0 prose-hr:pl-4 prose-hr:bg-transparent prose-pre:rounded-xl" set:html={html} />
