---
interface Props {
  html: string;
}

const { html } = Astro.props;
---

<div class="post-content prose dark:prose-invert max-w-none prose-headings:scroll-mt-20 prose-headings:font-medium prose-headings:tracking-tight prose-h2:text-[1.35rem] prose-h2:mt-10 prose-h2:mb-4 prose-h3:text-[1.125rem] prose-h3:mt-8 prose-h3:mb-3 prose-h4:text-base prose-p:text-base prose-p:leading-[1.75] prose-li:text-base prose-li:leading-[1.75] prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-a:font-normal prose-a:underline-offset-2 prose-img:rounded-xl prose-strong:font-medium prose-blockquote:font-normal prose-blockquote:not-italic prose-hr:border-gray-200 dark:prose-hr:border-white/[0.06] prose-pre:rounded-xl" set:html={html} />
