---
import type { TocItem } from '@/infrastructure/utils/markdown.util';

interface Props {
  items: TocItem[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <nav aria-label="Table of contents" class="p-4 rounded-xl glass-card">
    <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3 uppercase tracking-wider">On this page</h3>
    <ul class="space-y-1.5">
      {items.map((item) => (
        <li style={`padding-left: ${(item.level - 2) * 12}px`}>
          <a
            href={`#${item.id}`}
            class="text-sm text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors line-clamp-1"
          >
            {item.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
